# Frontend Environment Variables

# Development: Point to local backend running on port 5000
# The Vite proxy (vite.config.js) will forward /api/* requests to http://localhost:5000
VITE_API_BASE_URL=http://localhost:5000/api

# Production: Use relative path so frontend makes requests to its own host
# This works because the backend serves the frontend build from client/dist/
# So if app is at example.com, requests go to example.com/api/...
# VITE_API_BASE_URL=/api
